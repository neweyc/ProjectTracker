craytech-solutions.com {
    reverse_proxy craytech-ui:80

    log {
        output file /var/log/caddy/craytech-access.log
    }
}

oliveinvoice.com {
    # Reverse proxy for the API
    handle /api/* {
        reverse_proxy api:8080
    }

    # Reverse proxy for the UI
    handle {
        reverse_proxy ui:80
    }

    # Enable logging
    log {
        output file /var/log/caddy/access.log
    }
}
