# --- DATABASE ---
DB_CONNECTION_STRING=Server=db-server;Database=ProjectTracker;User Id=app-user;Password=your-password;

# --- STRIPE CONFIGURATION ---
# Get these from your Stripe Dashboard (Developers > API Keys)
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_PUBLISHABLE_KEY=pk_test_51...

# Create these in Stripe Dashboard (Products > Prices)
STRIPE_SOLO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# Get this by running `stripe listen` or from Webhook settings
STRIPE_WEBHOOK_SECRET=whsec_...

# --- APPLICATION ---
ASPNETCORE_ENVIRONMENT=Production
